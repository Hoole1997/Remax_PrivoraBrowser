<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/toolbar"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/white"
        app:contentInsetStartWithNavigation="0dp"
        app:title="">

        <TextView
            android:id="@+id/segmented_tabs"
            android:layout_width="wrap_content"
            android:text="@string/tab_settings"
            android:textColor="@color/black_333"
            android:textSize="16sp"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_gravity="center" />

    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:background="#F9F9FA"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_search_engine"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                app:shape_radius="12dp"
                app:shape_solidColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:id="@+id/iv_search_engine_icon"
                    android:src="@mipmap/ic_search_icon_google"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>

                <TextView
                    android:text="@string/search_engine"
                    android:textColor="@color/black_333"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/tv_search_engine_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Google"
                    android:layout_gravity="center_vertical"
                    android:textColor="@color/black_666"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_marginStart="10dp"
                    android:src="@drawable/ic_arrow_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </com.hjq.shape.layout.ShapeLinearLayout>

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_default_browser"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                app:shape_radius="12dp"
                app:shape_solidColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:src="@mipmap/ic_setting_default_browser"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>

                <TextView
                    android:text="@string/default_browser"
                    android:textColor="@color/black_333"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_default_browser"
                    android:layout_gravity="center_vertical"
                    app:thumbTint="@color/switch_thumb_tint"
                    app:trackTint="@color/switch_track_tint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </com.hjq.shape.layout.ShapeLinearLayout>

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_language"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                app:shape_radius="12dp"
                app:shape_solidColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:src="@mipmap/ic_setting_language"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>

                <TextView
                    android:text="@string/language"
                    android:textColor="@color/black_333"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/tv_language_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    tools:text="English"
                    android:layout_gravity="center_vertical"
                    android:textColor="@color/black_666"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_marginStart="10dp"
                    android:src="@drawable/ic_arrow_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </com.hjq.shape.layout.ShapeLinearLayout>

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_clear_history"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                app:shape_radius="12dp"
                app:shape_solidColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:src="@mipmap/ic_setting_clear_history"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>

                <TextView
                    android:text="@string/clear_history"
                    android:textColor="@color/black_333"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

            </com.hjq.shape.layout.ShapeLinearLayout>

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_feedback"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:shape_radius="12dp"
                app:shape_solidColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:src="@mipmap/ic_setting_feedback"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>

                <TextView
                    android:text="@string/feedback"
                    android:textColor="@color/black_333"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

            </com.hjq.shape.layout.ShapeLinearLayout>

            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_about"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                app:shape_radius="12dp"
                app:shape_solidColor="@color/white"
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:src="@mipmap/ic_setting_about"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>

                <TextView
                    android:text="@string/about"
                    android:textColor="@color/black_333"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

            </com.hjq.shape.layout.ShapeLinearLayout>

            <!-- Debug: 广告源切换（仅 Debug 模式显示） -->
            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/ll_ad_source"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:shape_radius="12dp"
                app:shape_solidColor="#FFF3E0"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                tools:visibility="visible">

                <ImageView
                    android:src="@drawable/ic_ads"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tint="#FF9800"/>

                <TextView
                    android:text="[Debug] 广告源"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/tv_ad_source_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="竞价"
                    android:layout_gravity="center_vertical"
                    android:textColor="#FF9800"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_marginStart="10dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="#FF9800"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </com.hjq.shape.layout.ShapeLinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>