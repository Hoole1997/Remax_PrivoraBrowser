<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_gray"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp">
    <FrameLayout
        android:id="@+id/adContainer"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <!-- 顶部指示器 -->
    <View
        android:layout_width="80dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_dialog_indicator" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/download_dialog_title"
        android:textColor="#000000"
        android:textSize="19sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- 文件信息卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/bg_file_card_white"
        android:gravity="center_vertical"
        android:layout_marginBottom="18dp">

        <!-- 文件图标 -->
        <ImageView
            android:id="@+id/iv_file_icon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_file_unknown_v2"
            android:scaleType="fitXY" />

        <!-- 文件信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp">

            <!-- 文件名 -->
            <TextView
                android:id="@+id/tv_file_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Y29tLndpbmRzY3JpYmUubWlsaXRh"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />

            <!-- 文件大小 -->
            <TextView
                android:id="@+id/tv_file_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="293 MB"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:layout_marginTop="6dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 编辑图标（保留但可以隐藏） -->
        <ImageView
            android:id="@+id/iv_edit"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_edit"
            android:tint="#CCCCCC"
            android:padding="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 下载按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_download"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="下载"
        app:cornerRadius="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#1A8FFF"
        android:elevation="0dp" />

</LinearLayout>
