<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="3dp"
    android:layout_marginBottom="3dp"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/bg_search_engine_item">

    <!-- 搜索引擎图标 -->
    <ImageView
        android:id="@+id/iv_engine_icon"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@mipmap/ic_search_icon_google"
        android:contentDescription="@string/search_engine" />

    <!-- 搜索引擎名称 -->
    <TextView
        android:id="@+id/tv_engine_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:text="Google"
        android:textColor="#333333"
        android:textSize="14sp" />

    <!-- 选中指示图标 -->
    <ImageView
        android:id="@+id/iv_check"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_search_engine_checked"
        android:visibility="gone"
        android:contentDescription="@string/search_engine" />

</LinearLayout>
