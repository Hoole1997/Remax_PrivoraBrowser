<?xml version="1.0" encoding="utf-8"?>
<!--
  按 Figma 设计稿 (node 18845-17120) 还原：
  - 顶部 326dp 高的星空 Hero 背景图，叠加右上角行星装饰；
  - Toolbar 透明叠在 Hero 之上，仅显示返回箭头；
  - 中部：标题 "Why uninstall AZ Recovery?" + 6 项原因 RadioGroup + 多行原因输入框；
  - 底部固定区：蓝色渐变胶囊主按钮 + 下方下划线灰色 "Uninstall" 文本 + 80dp 灰色广告位；
  - 所有 id 与文案保持原样，未替换。
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Hero 背景图：星空科技底图，撑开顶部 326dp，半透明叠在白底上 -->
<!--    <ImageView-->
<!--        android:id="@+id/ivHeroBg"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="match_parent"-->
<!--        android:alpha="0.69"-->
<!--        android:contentDescription="@null"-->
<!--        android:scaleType="centerCrop"-->
<!--        android:src="@drawable/bg_uninstall_hero"-->
<!--        app:layout_constraintTop_toTopOf="parent" />-->

    <!-- 右上行星装饰：放在 Hero 的右上区域 -->
    <ImageView
        android:id="@+id/ivHeroPlanet"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_marginTop="31dp"
        android:layout_marginEnd="17dp"
        android:alpha="0.82"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_uninstall_planet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Toolbar 透明叠在 Hero 之上 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:contentInsetStartWithNavigation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_uninstall_back" />

    <!-- 中部可滚动内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/btnStay"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="51dp"
            android:paddingBottom="16dp">

            <!-- 标题 Why uninstall AZ Recovery? -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:text="@string/uninstall_confirm_title"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 原因列表：每项 20dp 间距，drawableEnd 显示选中圆点 -->
            <RadioGroup
                android:id="@+id/rgReasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <RadioButton
                    android:id="@+id/rbDifficult"
                    style="@style/UninstallReasonRadio"
                    android:checked="true"
                    android:text="@string/uninstall_reason_difficult" />

                <RadioButton
                    android:id="@+id/rbAds"
                    style="@style/UninstallReasonRadio"
                    android:text="@string/uninstall_reason_ads" />

                <RadioButton
                    android:id="@+id/rbCantFind"
                    style="@style/UninstallReasonRadio"
                    android:text="@string/uninstall_reason_cant_find" />

                <RadioButton
                    android:id="@+id/rbNotRestore"
                    style="@style/UninstallReasonRadio"
                    android:text="@string/uninstall_reason_not_restore" />

                <RadioButton
                    android:id="@+id/rbRecovery"
                    style="@style/UninstallReasonRadio"
                    android:text="@string/uninstall_reason_recovery" />

                <RadioButton
                    android:id="@+id/rbOthers"
                    style="@style/UninstallReasonRadio"
                    android:text="@string/uninstall_reason_others" />

            </RadioGroup>

            <!-- 卸载原因多行输入框 -->
            <EditText
                android:id="@+id/etOtherReason"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_uninstall_reason_input"
                android:gravity="top|start"
                android:hint="@string/uninstall_reason_hint"
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!--
      主按钮：Don't uninstall yet
      用 AppCompatTextView 而非 Button，避免 Material3 主题把背景染成 colorPrimary。
      宽度 315dp 居中、高度 48dp、24dp 圆角胶囊、蓝色渐变。
    -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/btnStay"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_uninstall_primary_button"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="@string/uninstall_btn_stay"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/btnUninstall"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 次要按钮：Uninstall（带下划线） -->
    <TextView
        android:id="@+id/btnUninstall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:fontFamily="sans-serif-medium"
        android:padding="8dp"
        android:text="@string/uninstall_btn_uninstall"
        android:textColor="#999999"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/adContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 底部 80dp 灰色广告位 -->
    <FrameLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F6F6F6"
        android:minHeight="80dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
