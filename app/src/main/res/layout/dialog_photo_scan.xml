<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <LinearLayout
        android:layout_width="315dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_photo_scan_dialog"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="16dp">

        <!-- 关闭按钮 (X) - 右上角 -->
        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="end"
            android:layout_marginEnd="-4dp"
            android:layout_marginTop="-4dp"
            android:padding="7dp"
            android:src="@drawable/ic_photo_scan_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />

        <!-- 扫描动画图标 (旋转的spinner图片) -->
        <ImageView
            android:id="@+id/iv_scan_spinner"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_photo_scan_spinner" />

        <!-- 完成图标 -->
        <ImageView
            android:id="@+id/iv_done"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_photo_scan_done"
            android:visibility="gone" />

        <!-- 标题文字 -->
        <TextView
            android:id="@+id/tv_scan_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/photo_clean_scanning"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 文件路径 -->
        <TextView
            android:id="@+id/tv_file_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="middle"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#999999"
            android:textSize="12sp" />

        <!-- 进度条区域 -->
        <LinearLayout
            android:id="@+id/ll_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/pb_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_photo_scan_progress" />

            <TextView
                android:id="@+id/tv_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="0%"
                android:textColor="#087FFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 原生广告容器 -->
        <FrameLayout
            android:id="@+id/fl_native_ad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minHeight="66dp"
            android:visibility="gone" />

        <!-- 扫描结果文字 -->
        <TextView
            android:id="@+id/tv_result_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#666666"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 查看按钮 -->
        <TextView
            android:id="@+id/btn_view_result"
            android:layout_width="284dp"
            android:layout_height="42dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_photo_scan_btn"
            android:gravity="center"
            android:text="@string/photo_clean_view_results"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- 无结果文字 -->
        <TextView
            android:id="@+id/tv_no_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#999999"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
