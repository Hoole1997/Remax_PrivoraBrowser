<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- 顶部地址栏区域 - 使用 AppBarLayout 实现滑动隐藏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp">

        <RelativeLayout
            android:id="@+id/topBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@color/white"
            app:layout_scrollFlags="scroll|enterAlways|snap">

            <!-- 搜索框容器 -->
            <com.hjq.shape.layout.ShapeLinearLayout
                android:id="@+id/searchBarContainer"
                app:shape_radius="24dp"
                app:shape_strokeSize="1.5dp"
                app:shape_strokeColor="@color/home_search_stroke_color"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_toLeftOf="@id/tabCounterContainer"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- 左侧网站图标/Google图标 -->
                <androidx.cardview.widget.CardView
                    android:layout_marginStart="5dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ivSiteIcon"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:adjustViewBounds="false"
                        android:contentDescription="@string/home_search_text_hint"
                        android:padding="1dp"
                        android:scaleType="centerInside"
                        android:src="@mipmap/ic_logo" />

                </androidx.cardview.widget.CardView>

                <!-- URL 地址栏 -->
                <TextView
                    android:id="@+id/tvUrl"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:hint="@string/home_search_text_hint"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- 刷新/停止按钮 -->
                <ImageView
                    android:id="@+id/ivRefresh"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_search_text_hint"
                    android:padding="8dp"
                    android:src="@drawable/ic_browser_refresh" />

            </com.hjq.shape.layout.ShapeLinearLayout>

            <!-- 标签页计数器 -->
            <FrameLayout
                android:id="@+id/tabCounterContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tabCounterCard"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    app:strokeColor="@color/home_search_stroke_color"
                    app:strokeWidth="2dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvTabCount"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

        </RelativeLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 直接使用 GeckoEngineView 展示网页内容 -->
    <mozilla.components.browser.engine.gecko.GeckoEngineView
        android:id="@+id/engineView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:ignore="Instantiatable">

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_gravity="top"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            android:progressTint="@color/color_material_button"
            android:progressBackgroundTint="@android:color/transparent"/>

        <!-- Find in Page ViewStub -->
        <ViewStub
            android:id="@+id/stubFindInPage"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="top"
            android:inflatedId="@+id/findInPageView"
            android:layout="@layout/stub_find_in_page" />

        <FrameLayout
            android:id="@+id/flDownload"
            android:layout_gravity="right|bottom"
            android:layout_margin="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                app:cardCornerRadius="90dp"
                app:cardBackgroundColor="@color/color_material_button"
                android:layout_width="50dp"
                android:layout_height="50dp">

                <ImageView
                    android:id="@+id/iv_video_download"
                    android:src="@mipmap/ic_webview_video_download"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <ProgressBar
                    android:id="@+id/pb_video_check"
                    android:padding="10dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- 视频数量角标 -->
            <TextView
                android:id="@+id/tv_video_count"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_video_count_badge"
                android:gravity="center"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"/>

        </FrameLayout>

    </mozilla.components.browser.engine.gecko.GeckoEngineView>

    <!-- 底部导航栏 - 固定在底部 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="4dp"
        android:paddingVertical="4dp">

        <!-- 后退按钮 -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@drawable/ic_browser_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/app_name"/>

        <!-- 前进按钮 -->
        <ImageView
            android:id="@+id/ivForward"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@drawable/ic_browser_forward"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/app_name"/>

        <!-- 主页按钮 -->
        <ImageView
            android:id="@+id/ivHome"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@mipmap/ic_browser_home"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/app_name"/>

        <!-- 下载按钮 -->
        <ImageView
            android:id="@+id/ivDownload"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@mipmap/ic_browser_download"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/app_name"/>

        <!-- 更多菜单按钮 -->
        <ImageView
            android:id="@+id/ivMenu"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@mipmap/ic_browser_menu"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/app_name"/>

    </LinearLayout>

</LinearLayout>
