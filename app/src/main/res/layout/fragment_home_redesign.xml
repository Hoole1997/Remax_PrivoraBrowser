<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/searchRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="55dp"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.hjq.shape.layout.ShapeLinearLayout
            android:id="@+id/searchBarContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            app:shape_radius="24dp"
            app:shape_solidColor="@color/white"
            app:shape_strokeColor="@color/home_search_stroke_color"
            app:shape_strokeSize="1dp">

            <ImageView
                android:id="@+id/searchIcon"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:contentDescription="@string/home_search_text_hint"
                android:src="@mipmap/ic_search_icon_google" />

            <com.hjq.shape.view.ShapeTextView
                android:id="@+id/searchCardView"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:text="@string/home_search_text_hint"
                android:textColor="@color/home_search_text_hint_color"
                android:textSize="14sp"
                android:transitionName="search_transition" />

        </com.hjq.shape.layout.ShapeLinearLayout>

        <ImageView
            android:id="@+id/voiceSearchIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/home_search_text_hint"
            android:padding="8dp"
            android:src="@mipmap/ic_search_mic" />

        <ImageView
            android:id="@+id/qrCodeScanIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/home_search_text_hint"
            android:padding="8dp"
            android:src="@mipmap/ic_search_qr_code_scanner" />

    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchRow">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHomeFeed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
