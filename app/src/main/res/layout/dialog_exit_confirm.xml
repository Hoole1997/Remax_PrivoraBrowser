<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/exit_dialog_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_exit_dialog_top"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp">

        <!-- 顶部拖动条 -->
        <View
            android:layout_width="66dp"
            android:layout_height="8dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_exit_dialog_handle" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_exit_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/exit_confirm_title"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- 原生广告容器 -->
        <FrameLayout
            android:id="@+id/fl_exit_ad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <!-- 底部按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- 确认退出按钮 -->
            <TextView
                android:id="@+id/btn_confirm_exit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_exit_confirm_btn"
                android:gravity="center"
                android:text="@string/exit_confirm_exit"
                android:textColor="#666666"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="13dp"
                android:layout_height="0dp" />

            <!-- 取消按钮 -->
            <TextView
                android:id="@+id/btn_cancel_exit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_exit_cancel_btn"
                android:gravity="center"
                android:text="@string/exit_confirm_cancel"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
