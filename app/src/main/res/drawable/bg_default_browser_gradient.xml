<?xml version="1.0" encoding="utf-8"?>
<!--
    默认浏览器引导弹框背景
    顶部浅蓝 → 底部白色（angle=90 表示从底向上，所以 startColor 在底，endColor 在顶）
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#FFFFFFFF"
        android:centerColor="#FFEAF2FF"
        android:endColor="#FFD7E6FF" />
</shape>
