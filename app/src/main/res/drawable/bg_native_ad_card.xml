<?xml version="1.0" encoding="utf-8"?>
<!--
  原生广告卡背景：
  - 16dp 圆角，与新闻图片卡 (item_home_redesign_news.xml 中的 cv_news) 保持一致；
  - 极浅灰 #F8F9FB 填充，既能与白色 feed 背景区分，又不会喧宾夺主；
  - 1px 边框 #EEF1F5 增加层次感，避免广告卡看起来像一块"占位灰条"。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#F8F9FB" />

    <corners android:radius="16dp" />

    <stroke
        android:width="1dp"
        android:color="#EEF1F5" />

</shape>
