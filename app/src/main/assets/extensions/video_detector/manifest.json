{
  "manifest_version": 2,
  "name": "Video Detector",
  "version": "1.0.0",
  "description": "Detect video URLs from web pages",
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "permissions": [
    "webRequest",
    "webNavigation",
    "<all_urls>",
    "tabs",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "video-detector@example.browser"
    },
    "gecko_android": {
      "id": "video-detector@example.browser"
    }
  }
}
