<?xml version="1.0" encoding="utf-8"?>
<!-- Android 13 (API 33) 专用布局，高度限制约 94dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/noti_bg_r16_white"
    android:orientation="vertical"
    android:paddingTop="1dp"
    android:paddingBottom="1dp">

    <!-- 内容区域：图标 + 文字 (约 40dp) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <ImageView
                android:id="@+id/iv"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_noti_scan" />

            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:background="@drawable/noti_bg_badge"
                android:gravity="center"
                android:minWidth="14dp"
                android:minHeight="14dp"
                android:paddingHorizontal="2dp"
                android:text="12"
                android:textColor="#fff"
                android:textSize="9sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#333333"
            android:textSize="13sp"
            tools:text="Discover popular short videos curated for you." />

        <!-- 隐藏的标题，用于兼容代码设置 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 按钮区域 (32dp + 6dp margin = 38dp) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">

        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:indeterminate="true"
            android:indeterminateDrawable="@drawable/noti_timing_notify_btn_long"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <TextView
            android:id="@+id/tvAction"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="Clear"
            android:textColor="#fff"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

</LinearLayout>
