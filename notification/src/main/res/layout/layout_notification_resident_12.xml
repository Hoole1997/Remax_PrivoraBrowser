<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@drawable/noti_bg_r16_white"
    android:gravity="center_vertical"
    android:orientation="horizontal">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- 第一个按钮及标题 -->
        <RelativeLayout
            android:id="@+id/btn_container_1"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_clean"
                android:layout_marginTop="5dp"
                android:src="@mipmap/ic_noti_junk"
                android:layout_centerHorizontal="true"
                android:layout_width="38dp"
                android:layout_height="38dp"/>

            <TextView
                android:id="@+id/tv_message_number"
                android:text="!"
                android:textSize="10sp"
                android:textColor="@color/white"
                android:maxLength="2"
                android:gravity="center"
                android:background="@drawable/noti_circle_red"
                android:layout_alignTop="@id/iv_clean"
                android:layout_alignEnd="@id/iv_clean"
                android:layout_marginTop="-6.5dp"
                android:layout_marginEnd="-7.5dp"
                android:layout_width="15dp"
                android:layout_height="15dp"/>

        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/btn_container_2"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_marginTop="5dp"
                android:src="@mipmap/ic_noti_news"
                android:layout_centerHorizontal="true"
                android:layout_width="38dp"
                android:layout_height="38dp"/>


        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/btn_container_3"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_marginTop="5dp"
                android:src="@mipmap/ic_noti_process"
                android:layout_centerHorizontal="true"
                android:layout_width="38dp"
                android:layout_height="38dp"/>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/btn_container_4"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:gravity="center"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <ImageView
                android:layout_marginTop="5dp"
                android:src="@mipmap/ic_noti_scan"
                android:layout_width="38dp"
                android:layout_height="38dp"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>

